{
  "name": "maa-log-analyzer",
  "displayName": "Maa Log Analyzer",
  "description": "Maa Log Analyzer - Analyze MaaFramework log files",
  "version": "0.0.1",
  "publisher": "Windsland52",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaaXYZ/MaaLogAnalyzer"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "maaLogAnalyzer.openAnalyzer",
        "title": "Maa: 打开日志分析器"
      },
      {
        "command": "maaLogAnalyzer.analyzeFile",
        "title": "Maa: 分析此日志文件"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "maaLogAnalyzer.analyzeFile",
          "when": "resourceExtname == .log || resourceFilename =~ /maa.*\\.log/i",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "maaLogAnalyzer.analyzeFile",
          "when": "resourceExtname == .log",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run compile",
    "compile": "npm run typecheck && npm run bundle",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap --watch",
    "build:webview": "cd .. && pnpm build:vscode",
    "package": "vsce package"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.25.10",
    "typescript": "^5.3.0"
  }
}
